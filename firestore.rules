rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function activeUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status != 'banned';
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow create: if activeUser() && request.resource.data.employerId == request.auth.uid;
      allow update, delete: if isAdmin() || (activeUser() && resource.data.employerId == request.auth.uid);

      match /applications/{applicationId} {
        allow read: if isAdmin() || (signedIn() && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/jobs/$(jobId)).data.employerId == request.auth.uid));
        allow create: if activeUser() && request.resource.data.userId == request.auth.uid;
        allow delete: if isAdmin() || (activeUser() && resource.data.userId == request.auth.uid);
        allow update: if isAdmin() || (activeUser() && get(/databases/$(database)/documents/jobs/$(jobId)).data.employerId == request.auth.uid);
      }
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if activeUser() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAdmin() || (activeUser() && resource.data.authorId == request.auth.uid);

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if activeUser() && request.resource.data.authorId == request.auth.uid;
        allow delete: if isAdmin() || (activeUser() && resource.data.authorId == request.auth.uid);
      }

      match /likes/{userId} {
        allow read: if signedIn();
        allow create, delete: if activeUser() && userId == request.auth.uid;
      }
    }

    match /conversations/{conversationId} {
      allow read, update: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if activeUser() && request.auth.uid in request.resource.data.memberIds;

      match /messages/{messageId} {
        allow read: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberIds;
        allow create: if activeUser()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberIds;
      }
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn();
    }

    match /ratings/{ratingId} {
      allow read: if signedIn();
      allow create: if activeUser() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAdmin() || (activeUser() && resource.data.authorId == request.auth.uid);
    }

    match /subscriptions/{subscriptionId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }
  }
}
